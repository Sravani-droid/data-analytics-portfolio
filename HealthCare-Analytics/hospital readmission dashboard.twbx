              <calculation class='tableau' formula='IF [age] = &quot;[60-70)&quot; OR [age] = &quot;[70-80)&quot; OR [age] = &quot;[80-90)&quot; OR [age] = &quot;[90-100)&quot;&#13;&#10;THEN&#13;&#10;    IF [number_inpatient] &gt;= 2 OR [number_emergency] &gt;= 1 THEN &quot;High Risk&quot;&#13;&#10;    ELSE &quot;Normal&quot;&#13;&#10;    END&#13;&#10;ELSE &quot;Normal&quot;&#13;&#10;END' />
            </column>
