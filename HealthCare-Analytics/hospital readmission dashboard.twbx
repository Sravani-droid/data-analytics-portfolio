            <column-instance column='[patient_nbr]' derivation='None' name='[none:patient_nbr:ok]' pivot='key' type='ordinal' />
            <column caption='Number Inpatient' datatype='integer' name='[number_inpatient]' role='measure' type='quantitative' />
            <column caption='Patient Nbr' datatype='integer' name='[patient_nbr]' role='dimension' type='ordinal' />
            <column caption='Readmitted' datatype='string' name='[readmitted]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_1894794024906752]' derivation='Sum' name='[sum:Calculation_1894794024906752:qk]' pivot='key' type='quantitative' />
            <column-instance column='[number_inpatient]' derivation='Sum' name='[sum:number_inpatient:qk]' pivot='key' type='quantitative' />
            <column-instance column='[time_in_hospital]' derivation='Sum' name='[sum:time_in_hospital:qk]' pivot='key' type='quantitative' />
            <column caption='Time In Hospital' datatype='integer' default-format='n#,##0.0;-#,##0.0' name='[time_in_hospital]' role='measure' type='quantitative' />
          </datasource-dependencies>
          <shelf-sorts>
