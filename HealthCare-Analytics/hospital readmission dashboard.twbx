    <worksheet name='DiagnosisGroup Readmission'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#69aaa5' fontname='Benton Sans Book' fontsize='14'>Diabetes Patients Show Highest Readmission Risk</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='diabetic_data' name='federated.097020z0wktt3d1cpoik91iawwwa' />
          </datasources>
          <datasource-dependencies datasource='federated.097020z0wktt3d1cpoik91iawwwa'>
            <column caption='Readmission Flag' datatype='integer' name='[Calculation_1894794024906752]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [readmitted] = &quot;&lt;30&quot; THEN 1 ELSE 0 END' />
            </column>
            <column caption='Readmission Rate' datatype='real' default-format='p0.0%' name='[Calculation_1894794025066497]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG([Calculation_1894794024906752])' />
            </column>
            <column caption='Diagnosis Group' datatype='string' default-role='measure' default-type='quantitative' name='[Calculation_1894794025947143]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF ISNULL([diag_1]) THEN &quot;Other&quot;&#13;&#10;&#13;&#10;ELSEIF LEFT([diag_1],3) &gt;= &quot;390&quot; AND LEFT([diag_1],3) &lt;= &quot;459&quot; THEN &quot;Circulatory&quot;&#13;&#10;&#13;&#10;ELSEIF LEFT([diag_1],3) &gt;= &quot;460&quot; AND LEFT([diag_1],3) &lt;= &quot;519&quot; THEN &quot;Respiratory&quot;&#13;&#10;&#13;&#10;ELSEIF LEFT([diag_1],3) = &quot;250&quot; THEN &quot;Diabetes&quot;&#13;&#10;&#13;&#10;ELSE &quot;Other&quot;&#13;&#10;END' />
            </column>
            <column caption='Diag1_str' datatype='string' datatype-customized='true' default-role='measure' default-type='quantitative' name='[diag_1]' role='dimension' type='nominal' />
