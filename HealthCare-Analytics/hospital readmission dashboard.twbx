            </column>
            <column caption='Diagnosis Group' datatype='string' default-role='measure' default-type='quantitative' name='[Calculation_1894794025947143]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF ISNULL([diag_1]) THEN &quot;Other&quot;&#13;&#10;&#13;&#10;ELSEIF LEFT([diag_1],3) &gt;= &quot;390&quot; AND LEFT([diag_1],3) &lt;= &quot;459&quot; THEN &quot;Circulatory&quot;&#13;&#10;&#13;&#10;ELSEIF LEFT([diag_1],3) &gt;= &quot;460&quot; AND LEFT([diag_1],3) &lt;= &quot;519&quot; THEN &quot;Respiratory&quot;&#13;&#10;&#13;&#10;ELSEIF LEFT([diag_1],3) = &quot;250&quot; THEN &quot;Diabetes&quot;&#13;&#10;&#13;&#10;ELSE &quot;Other&quot;&#13;&#10;END' />
            </column>
            <column caption='Age' datatype='string' name='[age]' role='dimension' type='nominal' />
