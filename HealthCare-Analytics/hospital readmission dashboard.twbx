      <aliases enabled='yes' />
      <column caption='Readmission Flag' datatype='integer' name='[Calculation_1894794024906752]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [readmitted] = &quot;&lt;30&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Readmission Rate' datatype='real' default-format='p0.0%' name='[Calculation_1894794025066497]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Calculation_1894794024906752])' />
      </column>
      <column caption='HbA1c Tested Flag' datatype='integer' name='[Calculation_1894794025181186]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [A1Cresult] = &quot;None&quot; THEN 0 ELSE 1 END' />
      </column>
      <column caption='HbA1c Test Rate' datatype='real' default-format='p0.0%' name='[Calculation_1894794025422851]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Calculation_1894794025181186])' />
      </column>
      <column caption='High Risk Patient' datatype='string' name='[Calculation_1894794025611268]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [age] = &quot;[60-70)&quot; OR [age] = &quot;[70-80)&quot; OR [age] = &quot;[80-90)&quot; OR [age] = &quot;[90-100)&quot;&#13;&#10;THEN&#13;&#10;    IF [number_inpatient] &gt;= 2 OR [number_emergency] &gt;= 1 THEN &quot;High Risk&quot;&#13;&#10;    ELSE &quot;Normal&quot;&#13;&#10;    END&#13;&#10;ELSE &quot;Normal&quot;&#13;&#10;END' />
      </column>
      <column caption='High Risk Count' datatype='integer' name='[Calculation_1894794025701381]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_1894794025611268] = &quot;High Risk&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Estimated Readmit Cost' datatype='integer' name='[Calculation_1894794025844742]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1894794024906752] * 15400' />
      </column>
      <column caption='Diagnosis Group' datatype='string' default-role='measure' default-type='quantitative' name='[Calculation_1894794025947143]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF ISNULL([diag_1]) THEN &quot;Other&quot;&#13;&#10;&#13;&#10;ELSEIF LEFT([diag_1],3) &gt;= &quot;390&quot; AND LEFT([diag_1],3) &lt;= &quot;459&quot; THEN &quot;Circulatory&quot;&#13;&#10;&#13;&#10;ELSEIF LEFT([diag_1],3) &gt;= &quot;460&quot; AND LEFT([diag_1],3) &lt;= &quot;519&quot; THEN &quot;Respiratory&quot;&#13;&#10;&#13;&#10;ELSEIF LEFT([diag_1],3) = &quot;250&quot; THEN &quot;Diabetes&quot;&#13;&#10;&#13;&#10;ELSE &quot;Other&quot;&#13;&#10;END' />
      </column>
      <column caption='Stay Length Bucket' datatype='string' name='[Calculation_1894794026045448]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [time_in_hospital] &lt;= 3 THEN &quot;1-3 Days&quot;&#13;&#10;ELSEIF [time_in_hospital] &lt;= 7 THEN &quot;4-7 Days&quot;&#13;&#10;ELSE &quot;8+ Days&quot;&#13;&#10;END' />
      </column>
