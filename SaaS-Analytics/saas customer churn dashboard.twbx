      <aliases enabled='yes' />
      <column caption='Churn Flag' datatype='integer' name='[Calculation_0484394599714816]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Churn] = &quot;Yes&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Churn Rate' datatype='real' default-format='p0.0%' name='[Calculation_0484394599825409]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Calculation_0484394599714816])' />
      </column>
      <column caption='Revenue' datatype='real' name='[Calculation_0484394599907330]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[MonthlyCharges]' />
      </column>
      <column caption='ARPU' datatype='real' default-format='c&quot;$&quot;#,##0.0;(&quot;$&quot;#,##0.0)' name='[Calculation_0484394600013827]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([MonthlyCharges])' />
      </column>
      <column caption='Tenure Bucket' datatype='string' name='[Calculation_0484394600095748]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [tenure] &lt;= 12 THEN &quot;0-12 Months&quot;&#13;&#10;ELSEIF [tenure] &lt;= 24 THEN &quot;13-24 Months&quot;&#13;&#10;ELSEIF [tenure] &lt;= 48 THEN &quot;25-48 Months&quot;&#13;&#10;ELSE &quot;49+ Months&quot;&#13;&#10;END' />
      </column>
      <column caption='At Risk Flag' datatype='string' name='[Calculation_0484394600235013]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Contract] = &quot;Month-to-month&quot;&#13;&#10;AND [tenure] &lt;= 12&#13;&#10;AND [MonthlyCharges] &gt;= 70&#13;&#10;THEN &quot;At Risk&quot;&#13;&#10;ELSE &quot;Normal&quot;&#13;&#10;END' />
      </column>
      <column caption='At Risk Customer' datatype='integer' name='[Calculation_0484394600353798]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_0484394600235013] = &quot;At Risk&quot; THEN 1 ELSE 0 END' />
      </column>
