          <calculation class='tableau' formula='IF [MonthlyIncome] &lt; 3000 THEN &quot;Low&quot;&#13;&#10;ELSEIF [MonthlyIncome] &lt; 7000 THEN &quot;Medium&quot;&#13;&#10;ELSE &quot;High&quot;&#13;&#10;END' />
        </column>
        <column caption='Overtime Group' datatype='string' name='[Calculation_0575928812351491]' role='dimension' type='nominal'>
          <calculation class='tableau' formula='IF [OverTime] = &quot;Yes&quot; THEN &quot;Overtime&quot;&#13;&#10;ELSE &quot;No Overtime&quot;&#13;&#10;END' />
        </column>
        <column caption='AgeGroup' datatype='string' name='[Calculation_0575928827084806]' role='dimension' type='nominal'>
          <calculation class='tableau' formula='IF [Age] &lt; 25 THEN &quot;Under 25&quot;&#13;&#10;ELSEIF [Age] &lt; 35 THEN &quot;25-34&quot;&#13;&#10;ELSEIF [Age] &lt; 45 THEN &quot;35-44&quot;&#13;&#10;ELSEIF [Age] &lt; 55 THEN &quot;45-54&quot;&#13;&#10;ELSE &quot;55+&quot;&#13;&#10;END' />
