      <column caption='Business Travel' datatype='string' name='[BusinessTravel]' role='dimension' type='nominal' />
      <column caption='Attrition Flag' datatype='integer' default-format='p0.0%' name='[Calculation_0575928811827200]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Attrition] = &quot;Yes&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Attrition Rate' datatype='real' default-format='p0.0%' name='[Calculation_0575928811982849]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Calculation_0575928811827200])' />
      </column>
      <column caption='Salary band' datatype='string' name='[Calculation_0575928812105730]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [MonthlyIncome] &lt; 3000 THEN &quot;Low&quot;&#13;&#10;ELSEIF [MonthlyIncome] &lt; 7000 THEN &quot;Medium&quot;&#13;&#10;ELSE &quot;High&quot;&#13;&#10;END' />
      </column>
      <column caption='Overtime Group' datatype='string' name='[Calculation_0575928812351491]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [OverTime] = &quot;Yes&quot; THEN &quot;Overtime&quot;&#13;&#10;ELSE &quot;No Overtime&quot;&#13;&#10;END' />
      </column>
      <column caption='Estimated Turnover Cost' datatype='integer' default-format='c&quot;$&quot;#,##0,,.00M;(&quot;$&quot;#,##0,,.00M)' name='[Calculation_0575928812478468]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0575928811827200] * 22500' />
      </column>
      <column caption='Flight Risk Tier' datatype='string' name='[Calculation_0575928812912645]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [OverTime] = &quot;Yes&quot; AND [JobSatisfaction] &lt;= 2 AND [MonthlyIncome] &lt; 3000 THEN &quot;High Risk&quot;&#13;&#10;ELSEIF [OverTime] = &quot;Yes&quot; OR [JobSatisfaction] &lt;= 2 THEN &quot;Medium Risk&quot;&#13;&#10;ELSE &quot;Low Risk&quot;&#13;&#10;END' />
      </column>
      <column caption='AgeGroup' datatype='string' name='[Calculation_0575928827084806]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Age] &lt; 25 THEN &quot;Under 25&quot;&#13;&#10;ELSEIF [Age] &lt; 35 THEN &quot;25-34&quot;&#13;&#10;ELSEIF [Age] &lt; 45 THEN &quot;35-44&quot;&#13;&#10;ELSEIF [Age] &lt; 55 THEN &quot;45-54&quot;&#13;&#10;ELSE &quot;55+&quot;&#13;&#10;END' />
      </column>
      <column caption='Turnover Cost (M)' datatype='real' name='[Calculation_0575928846753799]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0575928812478468]) / 1000000' />
      </column>
