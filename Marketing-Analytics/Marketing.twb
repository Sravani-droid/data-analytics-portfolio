    <worksheet name='high Value Customers'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#69aaa5'>High Value Customers</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Sheet1 (marketing_campaign)' name='federated.15gzdjv1qypiha1684dwp0i1iakg' />
          </datasources>
          <datasource-dependencies datasource='federated.15gzdjv1qypiha1684dwp0i1iakg'>
            <column caption='Age' datatype='integer' name='[Calculation_1776597255106560]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='YEAR(TODAY()) - [Year_Birth]' />
            </column>
            <column caption='Age Group' datatype='string' name='[Calculation_1776597255168001]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_1776597255106560] &lt; 30 THEN &quot;Under 30&quot;&#13;&#10;ELSEIF [Calculation_1776597255106560] &lt; 45 THEN &quot;30-44&quot;&#13;&#10;ELSEIF [Calculation_1776597255106560] &lt; 60 THEN &quot;45-59&quot;&#13;&#10;ELSE &quot;60+&quot;&#13;&#10;END' />
            </column>
            <column caption='Total Spend' datatype='integer' default-format='c&quot;$&quot;#,##0.0;(&quot;$&quot;#,##0.0)' name='[Calculation_1776597255262210]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[MntWines] + [MntFruits] + [MntMeatProducts] + [MntFishProducts] + [MntSweetProducts] + [MntGoldProds]' />
            </column>
            <column caption='Customer Value Segment' datatype='string' name='[Calculation_1776597256015880]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_1776597255262210] &gt;= 1500 THEN &quot;High Value&quot;&#13;&#10;ELSEIF [Calculation_1776597255262210] &gt;= 700 THEN &quot;Mid Value&quot;&#13;&#10;ELSE &quot;Low Value&quot;&#13;&#10;END' />
            </column>
            <column caption='Preferred Channel' datatype='string' name='[Calculation_1776597256126473]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [NumWebPurchases] &gt;= [NumCatalogPurchases] AND [NumWebPurchases] &gt;= [NumStorePurchases] THEN &quot;Web&quot;&#13;&#10;ELSEIF [NumCatalogPurchases] &gt;= [NumWebPurchases] AND [NumCatalogPurchases] &gt;= [NumStorePurchases] THEN &quot;Catalog&quot;&#13;&#10;ELSE &quot;Store&quot;&#13;&#10;END' />
            </column>
            <column datatype='string' name='[Education]' role='dimension' type='nominal' />
            <column datatype='integer' name='[ID]' role='dimension' type='ordinal' />
            <column caption='Mnt Fish Products' datatype='integer' name='[MntFishProducts]' role='measure' type='quantitative' />
            <column caption='Mnt Fruits' datatype='integer' name='[MntFruits]' role='measure' type='quantitative' />
            <column caption='Mnt Gold Prods' datatype='integer' name='[MntGoldProds]' role='measure' type='quantitative' />
            <column caption='Mnt Meat Products' datatype='integer' name='[MntMeatProducts]' role='measure' type='quantitative' />
            <column caption='Mnt Sweet Products' datatype='integer' name='[MntSweetProducts]' role='measure' type='quantitative' />
            <column caption='Mnt Wines' datatype='integer' name='[MntWines]' role='measure' type='quantitative' />
            <column caption='Num Catalog Purchases' datatype='integer' name='[NumCatalogPurchases]' role='measure' type='quantitative' />
            <column caption='Num Store Purchases' datatype='integer' name='[NumStorePurchases]' role='measure' type='quantitative' />
            <column caption='Num Web Purchases' datatype='integer' name='[NumWebPurchases]' role='measure' type='quantitative' />
            <column caption='Year Birth' datatype='integer' name='[Year_Birth]' role='dimension' type='quantitative' />
            <column-instance column='[ID]' derivation='CountD' name='[ctd:ID:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1776597255168001]' derivation='None' name='[none:Calculation_1776597255168001:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_1776597256015880]' derivation='None' name='[none:Calculation_1776597256015880:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_1776597256126473]' derivation='None' name='[none:Calculation_1776597256126473:nk]' pivot='key' type='nominal' />
            <column-instance column='[Education]' derivation='None' name='[none:Education:nk]' pivot='key' type='nominal' />
          </datasource-dependencies>
          <slices>
            <column>[federated.15gzdjv1qypiha1684dwp0i1iakg].[none:Calculation_1776597256015880:nk]</column>
