      <aliases enabled='yes' />
      <column caption='Age' datatype='integer' name='[Calculation_1776597255106560]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='YEAR(TODAY()) - [Year_Birth]' />
      </column>
      <column caption='Age Group' datatype='string' name='[Calculation_1776597255168001]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1776597255106560] &lt; 30 THEN &quot;Under 30&quot;&#13;&#10;ELSEIF [Calculation_1776597255106560] &lt; 45 THEN &quot;30-44&quot;&#13;&#10;ELSEIF [Calculation_1776597255106560] &lt; 60 THEN &quot;45-59&quot;&#13;&#10;ELSE &quot;60+&quot;&#13;&#10;END' />
      </column>
      <column caption='Total Spend' datatype='integer' default-format='c&quot;$&quot;#,##0.0;(&quot;$&quot;#,##0.0)' name='[Calculation_1776597255262210]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[MntWines] + [MntFruits] + [MntMeatProducts] + [MntFishProducts] + [MntSweetProducts] + [MntGoldProds]' />
      </column>
      <column caption='Total Purchases' datatype='integer' default-format='n#,##0.0;-#,##0.0' name='[Calculation_1776597255618564]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[NumWebPurchases] + [NumCatalogPurchases] + [NumStorePurchases]' />
      </column>
      <column caption='Campaign Acceptance Count' datatype='integer' name='[Calculation_1776597255704581]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[AcceptedCmp1] + [AcceptedCmp2] + [AcceptedCmp3] + [AcceptedCmp4] + [AcceptedCmp5]' />
      </column>
      <column caption='Response Rate' datatype='real' default-format='p0.0%' name='[Calculation_1776597255811078]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Response])' />
      </column>
      <column caption='Previous Campaign Responder' datatype='string' name='[Calculation_1776597255897095]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1776597255704581] &gt; 0 THEN &quot;Responded Before&quot;&#13;&#10;ELSE &quot;No Prior Response&quot;&#13;&#10;END' />
      </column>
      <column caption='Customer Value Segment' datatype='string' name='[Calculation_1776597256015880]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1776597255262210] &gt;= 1500 THEN &quot;High Value&quot;&#13;&#10;ELSEIF [Calculation_1776597255262210] &gt;= 700 THEN &quot;Mid Value&quot;&#13;&#10;ELSE &quot;Low Value&quot;&#13;&#10;END' />
      </column>
      <column caption='Preferred Channel' datatype='string' name='[Calculation_1776597256126473]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [NumWebPurchases] &gt;= [NumCatalogPurchases] AND [NumWebPurchases] &gt;= [NumStorePurchases] THEN &quot;Web&quot;&#13;&#10;ELSEIF [NumCatalogPurchases] &gt;= [NumWebPurchases] AND [NumCatalogPurchases] &gt;= [NumStorePurchases] THEN &quot;Catalog&quot;&#13;&#10;ELSE &quot;Store&quot;&#13;&#10;END' />
      </column>
